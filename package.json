{
  "name": "ama-dot-me",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "pnpm gen:types && astro dev",
    "build": "pnpm gen:types && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fmt": "biome check --write .",
    "gen:types": "wrangler types ./src/worker-configuration.d.ts",
    "gen:migrations": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply ama-dot-me --local",
    "db:migrate:prod": "wrangler d1 migrations ama-dot-me <name>",
    "db:studio:local": "drizzle-kit studio"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "astro": "^6.1.8",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "htmx-ext-response-targets": "^2.0.4",
    "wrangler": "^4.84.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@libsql/client": "^0.17.2",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "htmx.org": "^2.0.8",
    "lefthook": "^2.1.6"
  },
  "overrides": {
    "vite": "^7"
  }
}
