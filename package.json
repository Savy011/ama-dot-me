{
  "name": "ama-dot-me",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm gen:types && astro build",
    "preview": "astro build && wrangler dev",
    "astro": "astro",
    "deploy": "pnpm gen:types && astro build && wrangler deploy",
    "deploy:email": "pnpm gen:types:email && wrangler deploy --config workers/wrangler.jsonc",
    "fmt": "biome check --write .",
    "gen:types": "wrangler types ./src/worker-configuration.d.ts",
    "gen:types:email": "wrangler types --config ./workers/wrangler.jsonc ./workers/worker-configuration.d.ts",
    "gen:migrations": "drizzle-kit generate",
    "gen:favicon": "node scripts/svg-to-ico.js",
    "db:migrate": "wrangler d1 migrations apply ama-dot-me --local",
    "db:migrate:prod": "wrangler d1 migrations apply ama-dot-me --remote",
    "db:studio:local": "drizzle-kit studio"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^1.0.0",
    "@astrojs/cloudflare": "^14.1.1",
    "@fontsource-variable/atkinson-hyperlegible-mono": "^5.2.5",
    "@fontsource-variable/faustina": "^5.2.8",
    "@fontsource/englebert": "^5.2.10",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.12",
    "astro": "^7.0.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "htmx-ext-response-targets": "^2.0.4",
    "nanoid": "^5.1.16",
    "png-to-ico": "^3.0.2",
    "postal-mime": "^2.7.5",
    "resend": "^6.17.1",
    "sharp": "^0.34.5",
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@libsql/client": "^0.17.4",
    "@types/node": "^25.9.4",
    "drizzle-kit": "^0.31.10",
    "htmx.org": "^2.0.10",
    "lefthook": "^2.1.9",
    "wrangler": "^4.107.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
