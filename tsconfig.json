{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*",
    "./src/env.d.ts",
    "./worker-configuration.d.ts"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "paths": {
      "$components/*": [
        "./src/components/*"
      ],
      "$lib/*": [
        "./src/lib/*"
      ],
      "$styles/*": [
        "./src/styles/*"
      ]
    }
  }
}
